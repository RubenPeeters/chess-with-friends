# ── Site / Caddy ──────────────────────────────────────────────────────────────
# Local dev: leave as :80 (plain HTTP)
# Production: set to your domain, e.g. chesswithfriends.gg
SITE_ADDR=:80
# Required in production for Let's Encrypt — Caddy uses this for ACME registration
CADDY_ACME_EMAIL=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://chess:changeme@postgres:5432/chess
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_this_to_a_long_random_secret

# ── OAuth — Google ────────────────────────────────────────────────────────────
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# ── OAuth — GitHub ────────────────────────────────────────────────────────────
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# ── Object Storage (AWS S3 or Backblaze B2) ───────────────────────────────────
S3_BUCKET=chess-with-friends
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Leave blank for AWS; set for B2 or other S3-compatible providers, e.g.:
# S3_ENDPOINT=https://s3.us-west-004.backblazeb2.com
S3_ENDPOINT=
