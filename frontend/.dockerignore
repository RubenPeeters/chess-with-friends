# The frontend image rebuilds dependencies and assets from scratch via
# `RUN npm install` and `RUN npm run build` in the Dockerfile, so anything
# generated locally on the host should NOT be sent into the build context.
# Without this file, `COPY . .` would ship all of these into the image only
# to immediately overwrite or discard them.

# Host dependency tree — `npm install` re-creates this inside the container.
node_modules

# Vite output — regenerated by `npm run build` inside the container.
dist
.vite

# Stockfish engine assets — copied from node_modules into public/stockfish/
# by the stockfishAssets plugin in vite.config.js. Re-created inside the
# container during `npm run build`. ~40 MB of NNUE weights, so excluding
# this matters for build context size.
public/stockfish

# Local env / IDE / OS noise
.env
.env.local
.env.development
.git
.gitignore
.vscode
.idea
*.log
.DS_Store
Thumbs.db
