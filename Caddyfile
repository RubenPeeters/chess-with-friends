{
	admin off
	# CADDY_ACME_EMAIL must be set in .env for production HTTPS.
	# For local dev (SITE_ADDR=:80) Caddy won't request certificates so
	# the email is ignored — but we still require it to be set so that
	# a production deploy never silently skips ACME registration.
	email {$CADDY_ACME_EMAIL:}
}

# SITE_ADDR is injected from the .env file:
#   • Production:  SITE_ADDR=chesswithfriends.gg
#   • Local dev:   SITE_ADDR=:80
{$SITE_ADDR} {

	# WebSocket game connections
	handle /ws* {
		reverse_proxy game:4000
	}

	# Social service — flush_interval -1 required for SSE streaming
	handle /api/social/* {
		uri strip_prefix /api/social
		reverse_proxy social:3001 {
			flush_interval -1
		}
	}

	# Auth + general API
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy api:3000
	}

	# Frontend
	handle {
		reverse_proxy frontend:80
	}
}
