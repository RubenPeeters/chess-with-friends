{
	admin off
	# Caddy automatically provisions and renews Let's Encrypt TLS.
	# Set your email so Let's Encrypt can contact you about expiry.
	email {$CADDY_ACME_EMAIL}
}

# ── Site definition ───────────────────────────────────────────────────────────
# SITE_ADDR is injected from the .env file:
#   • Production:  SITE_ADDR=chesswithfriends.gg   (your domain)
#   • Local dev:   SITE_ADDR=:80                    (plain HTTP, no TLS)
{$SITE_ADDR} {

	# WebSocket game connections (Caddy auto-detects the Upgrade header)
	handle /ws* {
		reverse_proxy game:4000
	}

	# Social service — flush_interval -1 required for SSE streaming
	handle /api/social/* {
		uri strip_prefix /api/social
		reverse_proxy social:3001 {
			flush_interval -1
		}
	}

	# Auth + general API
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy api:3000
	}

	# Frontend — served by the nginx container in production
	handle {
		reverse_proxy frontend:80
	}
}
